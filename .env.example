TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_API_BASE=https://your-openai-compatible-endpoint.example/
GEMINI_MODEL=replace-with-model-name
TAVILY_API_KEY=

# Telegram private invite links cannot be matched from message updates.
# Add the bot to the group, send /chatid, then put that numeric id here.
ALLOWED_CHAT_ID=
ALLOWED_USER_ID=
NO_PERMISSION_TEXT=无权限。
QUESTION_PREFIX=

# Optional: adjust how the assistant behaves.
SYSTEM_PROMPT=你是一个在 Telegram 群聊中回答问题的中文助手。回答应清晰、准确、简洁。
REQUEST_TIMEOUT_SECONDS=60
